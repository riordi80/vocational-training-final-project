<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:padding="16dp"
    tools:context=".activities.Login">

    <!-- Logo -->
    <TextView
        android:id="@+id/textViewLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="🌳"
        android:textSize="72sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Título -->
    <TextView
        android:id="@+id/textViewTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Proyecto Árboles"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/green_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewLogo" />

    <!-- Layout del formulario de login -->
    <LinearLayout
        android:id="@+id/layoutLoginForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewTitulo">

        <!-- Label Usuario -->
        <TextView
            android:id="@+id/textViewUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuario"
            android:layout_marginStart="32dp"/>

        <!-- Campo Usuario -->
        <EditText
            android:id="@+id/editTextUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:hint="Introduzca su usuario"
            android:inputType="text"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"/>

        <!-- Label Contraseña -->
        <TextView
            android:id="@+id/textViewPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Contraseña"
            android:layout_marginStart="32dp"/>

        <!-- Campo Contraseña -->
        <EditText
            android:id="@+id/editTextPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:hint="Introduzca su contraseña"
            android:inputType="textPassword"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"/>

        <!-- Botón Iniciar Sesión -->
        <Button
            android:id="@+id/buttonLogin"
            style="@style/ButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="32dp"
            android:text="Iniciar Sesión" />

        <!-- Botón Registrarse -->
        <Button
            android:id="@+id/buttonRegistrer"
            style="@style/ButtonOutline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="32dp"
            android:text="Registrarse" />

    </LinearLayout>

    <!-- Layout de logout (visible cuando hay sesión activa y no es admin) -->
    <LinearLayout
        android:id="@+id/layoutLogout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewTitulo">

        <!-- Icono de usuario -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_nav_usuarios"
            android:background="@drawable/circle_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Mensaje de usuario logueado -->
        <TextView
            android:id="@+id/textViewUsuarioLogueado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sesión activa"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textAlignment="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Desea cerrar sesión?"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"/>

        <!-- Botón Cerrar Sesión -->
        <Button
            android:id="@+id/buttonCerrarSesion"
            style="@style/ButtonPrimary"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Cerrar Sesión"
            android:backgroundTint="@color/red_primary"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>